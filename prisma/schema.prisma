generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

model PriceGuard {
  id        String   @id @default(cuid())
  shop      String   @default("matrix-warehouse-sa.myshopify.com")
  sku       String
  minPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, sku])
  @@index([shop])
  @@index([sku])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  label     String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs EmailLog[]
}

model EmailLog {
  id         Int      @id @default(autoincrement())
  orderGid   String
  templateId Int
  subject    String
  bodyHtml   String
  sentAt     DateTime @default(now())

  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([sentAt])
}

model ProductAuditRun {
  id         String   @id @default(cuid())
  shop       String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  checked    Int      @default(0)
  drafted    Int      @default(0)
  status     String   @default("running") // running | completed | failed
  error      String?

  items ProductAuditItem[]
  scans ProductAuditScan[]

  @@index([shop])
  @@index([startedAt])
}

model ProductAuditItem {
  id                 String   @id @default(cuid())
  runId              String
  shop               String
  productGid         String
  title              String
  prevStatus         String
  newStatus          String
  missingDescription Boolean
  missingImages      Boolean
  createdAt          DateTime @default(now())

  run ProductAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([shop])
  @@index([productGid])

  // Optional but recommended:
  @@unique([runId, productGid])
}

model ProductAuditScan {
  id                 String   @id @default(cuid())
  runId              String
  shop               String
  productGid         String
  title              String
  status             String
  missingDescription Boolean
  missingImages      Boolean
  actionTaken        String   // NONE | WOULD_DRAFT | DRAFT
  createdAt          DateTime @default(now())

  run ProductAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([shop])
  @@index([productGid])

  // Recommended:
  @@unique([runId, productGid])
}