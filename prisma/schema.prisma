generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

model PriceGuard {
  id              String   @id @default(cuid())
  shop            String   @default("matrix-warehouse-sa.myshopify.com")
  sku             String
  minPrice        Float

  // new fields for safer matching + future exact price lock
  variantId       String?
  productId       String?
  mode            String?  // MIN_ONLY | EXACT_LOCK
  lockedPrice     Float?
  isEnabled       Boolean  @default(true)
  lastCorrectedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, sku])
  @@index([shop])
  @@index([sku])
  @@index([variantId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  label     String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs EmailLog[]
}

model EmailLog {
  id         Int      @id @default(autoincrement())
  orderGid   String
  templateId Int
  subject    String
  bodyHtml   String
  sentAt     DateTime @default(now())

  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([sentAt])
}

model ProductAuditRun {
  id         String   @id @default(cuid())
  shop       String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  checked    Int      @default(0)
  drafted    Int      @default(0)
  status     String   @default("running") // running | completed | failed
  error      String?

  items ProductAuditItem[]
  scans ProductAuditScan[]

  @@index([shop])
  @@index([startedAt])
}

model ProductAuditItem {
  id                 String   @id @default(cuid())
  runId              String
  shop               String
  productGid         String
  title              String
  prevStatus         String
  newStatus          String
  missingDescription Boolean
  missingImages      Boolean
  createdAt          DateTime @default(now())

  run ProductAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([shop])
  @@index([productGid])

  @@unique([runId, productGid])
}

model ProductAuditScan {
  id                 String   @id @default(cuid())
  runId              String
  shop               String
  productGid         String
  title              String
  status             String
  missingDescription Boolean
  missingImages      Boolean
  actionTaken        String   // NONE | WOULD_DRAFT | DRAFT
  createdAt          DateTime @default(now())

  run ProductAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([shop])
  @@index([productGid])

  @@unique([runId, productGid])
}

model UpsellRule {
  id                    String   @id @default(cuid())
  shop                  String
  name                  String
  type                  UpsellRuleType
  placement             UpsellPlacement
  triggerMode           UpsellTriggerMode

  triggerProductId      String?
  triggerVariantId      String?
  triggerSku            String?
  triggerTag            String?
  triggerCollectionId   String?
  triggerDiscountMode   UpsellDiscountMode @default(NONE)
  triggerDiscountValue  Float?
  triggerDiscountLabel  String?

  minCartValue          Float?
  maxCartValue          Float?

  priority              Int      @default(100)
  isActive              Boolean  @default(true)
  limitOnePerCart       Boolean  @default(true)
  hideIfOfferInCart     Boolean  @default(true)
  hideIfOfferOutOfStock Boolean  @default(true)

  startsAt              DateTime?
  endsAt                DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  offerProducts         UpsellOfferProduct[]

  @@index([shop])
  @@index([shop, isActive])
  @@index([shop, placement])
  @@index([shop, triggerProductId])
  @@index([shop, triggerVariantId])
  @@index([shop, triggerSku])
  @@index([shop, triggerTag])
  @@index([shop, triggerCollectionId])
}

model UpsellOfferProduct {
  id                 String   @id @default(cuid())
  ruleId             String
  position           Int      @default(0)

  offerMode          UpsellOfferMode
  offerProductId     String?
  offerVariantId     String?
  offerSku           String?

  offerTitleOverride String?
  offerMessage       String?

  discountMode       UpsellDiscountMode @default(NONE)
  discountValue      Float?
  discountLabel      String?

  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rule               UpsellRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([ruleId, position])
}

enum UpsellRuleType {
  UPSELL
  CROSS_SELL
}

enum UpsellPlacement {
  PRODUCT_PAGE
  CART
  CART_DRAWER
  POST_ADD
}

enum UpsellTriggerMode {
  PRODUCT
  VARIANT
  SKU
  TAG
  COLLECTION
  CART_VALUE
}

enum UpsellOfferMode {
  PRODUCT
  VARIANT
  SKU
}

enum UpsellDiscountMode {
  NONE
  FIXED
  PERCENTAGE
}