// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // <-- IMPORTANT: use a variable, not the file path
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model PriceGuard {
  id        String   @id @default(cuid())
  shop      String   @default("matrix-warehouse-sa.myshopify.com") // existing rules = Matrix
  sku       String
  minPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, sku]) // one rule per SKU per shop
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  label     String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔴 This is the missing opposite side
  logs EmailLog[]
}

model EmailLog {
  id         Int      @id @default(autoincrement())
  orderGid   String
  templateId Int
  subject    String
  bodyHtml   String
  sentAt     DateTime @default(now())

  // Relation to EmailTemplate
  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}
